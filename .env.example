# Bot Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Cookie Twitter untuk akses konten age-restricted
# Buka twitter.com > F12 > Application > Cookies
TWITTER_AUTH_TOKEN=your_auth_token_cookie_here
TWITTER_CT0=your_ct0_cookie_here

# Admin Telegram ID (opsional)
ADMIN_ID=

# Batas ukuran file maksimal (MB), default 50
MAX_FILE_SIZE=50

# Webhook (opsional, untuk Railway/VPS)
# Kosongkan untuk mode polling
WEBHOOK_URL=
PORT=8080
